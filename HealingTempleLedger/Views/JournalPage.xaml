<Page x:Class="HealingTempleLedger.Views.JournalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="📝 Journal Entries">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,16">
            <StackPanel>
                <TextBlock Text="📝 Journal Entries" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Double-entry journal — debits must equal credits"
                           Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
            </StackPanel>
        </Border>
        <Grid>
        <DockPanel Margin="24,20">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📝 Journal Entries" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Double-entry accounting — debits must equal credits for each entry"
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                </StackPanel>
                <Button Content="➕ New Journal Entry" Style="{StaticResource AccentButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Padding="14,9" Click="NewEntry_Click"/>
            </DockPanel>
            <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    Padding="16,10" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="ENTRIES" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                        <TextBlock x:Name="JournalCount" Text="0" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="TOTAL DEBITS" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                        <TextBlock x:Name="JournalDebits" Text="$0.00" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}" FontFamily="{StaticResource MonoFont}"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="TOTAL CREDITS" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                        <TextBlock x:Name="JournalCredits" Text="$0.00" FontSize="20" FontWeight="Bold"
                                   Foreground="{StaticResource WarnBrush}" FontFamily="{StaticResource MonoFont}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <DataGrid x:Name="JournalGrid" IsReadOnly="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="100"/>
                    <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="120"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat=C2}" Width="100"/>
                    <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat=C2}" Width="100"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        </Grid>
    </DockPanel>
</Page>
