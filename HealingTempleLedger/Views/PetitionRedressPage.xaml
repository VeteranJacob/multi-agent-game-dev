<Page x:Class="HealingTempleLedger.Views.PetitionRedressPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="📋 Petition for Redress">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,16">
            <StackPanel>
                <TextBlock Text="📋 Petition for Redress" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="First Amendment right to petition government for redress of grievances"
                           Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
            </StackPanel>
        </Border>
        <Grid>
        <ScrollViewer>
            <StackPanel Margin="28,20" MaxWidth="900">
                <Border Background="{StaticResource Surface2Brush}" CornerRadius="8"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                        Padding="20,14" Margin="0,0,0,20">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="13">
                        <Run FontWeight="Bold" Foreground="{StaticResource AccentBrush}">FIRST AMENDMENT — RIGHT TO PETITION: </Run>
                        <Run>"Congress shall make no law... abridging the right of the people... to petition the Government for a redress of grievances." The Healing Temple Ledger Petition for Redress (PFR) provides a lawful, voluntary framework for individuals to formally assert their rights and demand remedy from government.</Run>
                    </TextBlock>
                </Border>
                <TextBlock Text="DRAFT YOUR PETITION FOR REDRESS" Foreground="{StaticResource AccentBrush}"
                           FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Your Full Name" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="PetitionerName" Height="32"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Date" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <DatePicker x:Name="PetitionDate"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Addressee (Government Body)" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="Addressee" Text="The Congress of the United States" Height="32" Margin="0,0,0,12"/>
                <TextBlock Text="Nature of Grievance" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="GrievanceText" Height="120" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"
                         Text="Describe your grievance and the specific redress you are seeking..."/>
                <TextBlock Text="Redress Demanded" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="RedressText" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"
                         Text="State the specific remedy, action, or acknowledgment you are requesting..."/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="📄 Generate Petition" Style="{StaticResource AccentButton}"
                            Padding="16,10" Click="Generate_Click"/>
                    <Button Content="💾 Save Draft" Margin="8,0,0,0" Padding="16,10" Click="Save_Click"/>
                    <Button Content="🖨 Export" Margin="8,0,0,0" Padding="16,10" Click="Export_Click"/>
                </StackPanel>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,16,0,0">
                    <TextBox x:Name="GeneratedPetition" TextWrapping="Wrap" AcceptsReturn="True"
                             IsReadOnly="False" Height="300" VerticalScrollBarVisibility="Auto"
                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                             Text="Your petition will appear here after clicking Generate..."/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        </Grid>
    </DockPanel>
</Page>
