<Page x:Class="HealingTempleLedger.Views.FinancialStatementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="📑 Financial Statements">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,16">
            <StackPanel>
                <TextBlock Text="📑 Financial Statements" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Balance Sheet · Income Statement · Cash Flow Statement"
                           Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
            </StackPanel>
        </Border>
        <Grid>
        <ScrollViewer>
            <StackPanel Margin="28,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Button Content="🔄 Refresh" Style="{StaticResource AccentButton}" Padding="14,9" Click="Refresh_Click" Margin="0,0,8,0"/>
                    <Button Content="📊 Export Excel" Padding="14,9" Click="ExportExcel_Click"/>
                </StackPanel>
                <UniformGrid Columns="3" Margin="0,0,0,20">
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="TOTAL REVENUE" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                            <TextBlock x:Name="TotalRevenue" Text="$0.00" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" FontFamily="{StaticResource MonoFont}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,12" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="TOTAL EXPENSES" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                            <TextBlock x:Name="TotalExpenses" Text="$0.00" FontSize="22" FontWeight="Bold" Foreground="{StaticResource WarnBrush}" FontFamily="{StaticResource MonoFont}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="NET INCOME" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                            <TextBlock x:Name="NetIncome" Text="$0.00" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="INCOME STATEMENT" Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,0,0,12"/>
                            <DataGrid x:Name="IncomeGrid" IsReadOnly="True" AutoGenerateColumns="False" Height="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C2}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="20">
                        <StackPanel>
                            <TextBlock Text="BALANCE SHEET (SUMMARY)" Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,0,0,12"/>
                            <DataGrid x:Name="BalanceGrid" IsReadOnly="True" AutoGenerateColumns="False" Height="300">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Account Type" Binding="{Binding Type}" Width="*"/>
                                    <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat=C2}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        </Grid>
    </DockPanel>
</Page>
