<Page x:Class="HealingTempleLedger.Views.CongressionalPetitionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="🏛 Congressional Memorial Petition">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,16">
            <StackPanel>
                <TextBlock Text="🏛 Congressional Memorial Petition" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="Memorial and Congressional Legislative Petition (CLMP)"
                           Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
            </StackPanel>
        </Border>
        <Grid>
        <ScrollViewer>
            <StackPanel Margin="28,20" MaxWidth="900">
                <Border Background="{StaticResource Surface2Brush}" CornerRadius="8"
                        BorderBrush="{StaticResource Accent2Brush}" BorderThickness="1"
                        Padding="16,12" Margin="0,0,0,20">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextBrush}" FontSize="13">
                        <Run FontWeight="Bold" Foreground="{StaticResource Accent2Brush}">MEMORIAL AND CONGRESSIONAL PETITION (CLMP): </Run>
                        <Run>A Memorial Petition is a formal communication to a legislative body requesting specific action. This tool helps you draft a congressional memorial petition addressing emergency power governance, constitutional restoration, or other legislative matters.</Run>
                    </TextBlock>
                </Border>
                <TextBlock Text="PETITION DETAILS" Foreground="{StaticResource AccentBrush}"
                           FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Petitioner Name" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="PetitionerName" Height="32"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                        <TextBlock Text="Representative / Senator" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="Representative" Height="32"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="State" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                        <TextBox x:Name="StateBox" Height="32"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="Subject Matter" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                <ComboBox x:Name="SubjectCombo" Margin="0,0,0,12" Height="32">
                    <ComboBoxItem Content="Termination of Continuous National Emergency"/>
                    <ComboBoxItem Content="Restoration of Constitutional Governance"/>
                    <ComboBoxItem Content="Trading with the Enemy Act — Domestic Application"/>
                    <ComboBoxItem Content="Emergency Powers — Congressional Oversight"/>
                    <ComboBoxItem Content="Custom Subject"/>
                </ComboBox>
                <TextBlock Text="Memorial Statement" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,4"/>
                <TextBox x:Name="MemorialText" Height="140" TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="📄 Generate Memorial" Style="{StaticResource AccentButton}"
                            Padding="16,10" Click="Generate_Click"/>
                    <Button Content="🖨 Export" Margin="8,0,0,0" Padding="16,10" Click="Export_Click"/>
                </StackPanel>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,16,0,0">
                    <TextBox x:Name="GeneratedPetition" TextWrapping="Wrap" AcceptsReturn="True"
                             IsReadOnly="False" Height="300" VerticalScrollBarVisibility="Auto"
                             FontFamily="{StaticResource MonoFont}" FontSize="12"
                             Text="Your congressional memorial petition will appear here..."/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        </Grid>
    </DockPanel>
</Page>
