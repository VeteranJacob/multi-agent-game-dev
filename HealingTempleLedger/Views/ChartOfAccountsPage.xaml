<Page x:Class="HealingTempleLedger.Views.ChartOfAccountsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="📋 Chart of Accounts">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,16">
            <StackPanel>
                <TextBlock Text="📋 Chart of Accounts" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="GAAP-standard account structure"
                           Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
            </StackPanel>
        </Border>
        <Grid>
        <DockPanel Margin="24,20">
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📋 Chart of Accounts" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="GAAP-standard account codes — Assets, Liabilities, Equity, Revenue, Expenses"
                               Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="➕ Add Account" Style="{StaticResource AccentButton}"
                            Padding="14,9" Click="AddAccount_Click"/>
                </StackPanel>
            </DockPanel>
            <DataGrid x:Name="AccountsGrid" IsReadOnly="True" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="70"/>
                    <DataGridTextColumn Header="Account Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                    <DataGridTextColumn Header="Sub-Type" Binding="{Binding SubType}" Width="150"/>
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        </Grid>
    </DockPanel>
</Page>
