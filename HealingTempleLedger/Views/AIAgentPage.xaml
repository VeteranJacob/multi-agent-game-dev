<Page x:Class="HealingTempleLedger.Views.AIAgentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="AI Agent Chat">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Agent Selector -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="AI AGENTS" Margin="14,16,14,8"
                           Foreground="{StaticResource TextDimBrush}" FontSize="10"
                           FontFamily="{StaticResource MonoFont}"/>
                <StackPanel DockPanel.Dock="Bottom" Margin="12,8">
                    <Button Content="🗑 Clear Chat" Click="ClearChat_Click"/>
                    <Button Content="💾 Export Chat" Margin="0,6,0,0" Click="ExportChat_Click"/>
                </StackPanel>
                <ListBox x:Name="AgentList" SelectionChanged="AgentList_SelectionChanged">
                    <ListBoxItem Tag="general">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="🤖 General Assistant" FontWeight="SemiBold"/>
                            <TextBlock Text="All-purpose AI helper" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="gaap">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="📊 GAAP Advisor" FontWeight="SemiBold"/>
                            <TextBlock Text="Accounting &amp; GAAP principles" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="legal">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="⚖ Legal Researcher" FontWeight="SemiBold"/>
                            <TextBlock Text="Emergency powers &amp; law" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="consumer">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="🛡 Consumer Rights" FontWeight="SemiBold"/>
                            <TextBlock Text="Disputes, chargebacks, rights" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="tax">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="🧾 Tax Advisor" FontWeight="SemiBold"/>
                            <TextBlock Text="IRS forms, tax strategy" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="document">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="📄 Document Drafter" FontWeight="SemiBold"/>
                            <TextBlock Text="Letters, petitions, forms" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="research">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="🔍 Research Agent" FontWeight="SemiBold"/>
                            <TextBlock Text="Historical &amp; factual research" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="financial">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="💰 Financial Planner" FontWeight="SemiBold"/>
                            <TextBlock Text="Budgeting, planning, analysis" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="trust">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="🏛 Trust &amp; Estate" FontWeight="SemiBold"/>
                            <TextBlock Text="Trusts, estates, Form 1041" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="corporate">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="🏢 Corporate Advisor" FontWeight="SemiBold"/>
                            <TextBlock Text="Corp structure, Form 1120" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="nonprofit">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="🤝 Nonprofit CPA" FontWeight="SemiBold"/>
                            <TextBlock Text="501(c) orgs, Form 990" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="petition">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="📋 Petition Advisor" FontWeight="SemiBold"/>
                            <TextBlock Text="Redress, petitions, rights" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="humanizer">
                        <StackPanel Margin="2,0">
                            <TextBlock Text="✍ AI Humanizer" FontWeight="SemiBold"/>
                            <TextBlock Text="Rewrite AI text naturally" FontSize="10"
                                       Foreground="{StaticResource TextDimBrush}"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Right Panel: Chat -->
        <DockPanel Grid.Column="1" Margin="0">

            <!-- Agent Header -->
            <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="20,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="AgentTitle" Text="🤖 General Assistant"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AgentDesc" Text="  ·  All-purpose AI helper"
                               Foreground="{StaticResource TextDimBrush}" VerticalAlignment="Center" FontSize="12"/>
                    <TextBlock x:Name="ProviderTag" Text="  ·  Offline mode"
                               Foreground="{StaticResource WarnBrush}" VerticalAlignment="Center" FontSize="11"
                               FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
            </Border>

            <!-- Input -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="MessageInput" Grid.Column="0" MinLines="2" MaxLines="5"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Placeholder.Text="Ask your AI agent anything…"
                             Margin="0,0,10,0"
                             KeyDown="MessageInput_KeyDown"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                        <Button x:Name="SendBtn" Content="Send ▶"
                                Style="{StaticResource AccentButton}"
                                Padding="16,10" Click="Send_Click"
                                IsEnabled="True"/>
                        <TextBlock x:Name="StatusText" Text="" FontSize="10"
                                   Foreground="{StaticResource TextDimBrush}" Margin="0,4,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chat History -->
            <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ChatList" Margin="0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="16,6" CornerRadius="8"
                                    Background="{Binding Background}"
                                    Padding="14,10" MaxWidth="820"
                                    HorizontalAlignment="{Binding Alignment}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Header}"
                                               FontSize="10" FontFamily="{StaticResource MonoFont}"
                                               Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                               Foreground="{StaticResource TextBrush}" FontSize="13"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Page>
