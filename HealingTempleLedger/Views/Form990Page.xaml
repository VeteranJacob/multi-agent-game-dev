<Page x:Class="HealingTempleLedger.Views.Form990Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="🤝 Form 990">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,16">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="🤝 Form 990" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Return of Organization Exempt From Income Tax" Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="🧮 Calculate" Padding="14,9" Margin="0,0,8,0" Click="Calculate_Click"/>
                    <Button Content="💾 Save" Style="{StaticResource AccentButton}" Padding="14,9" Margin="0,0,8,0" Click="Save_Click"/>
                    <Button Content="📊 Export Excel" Padding="14,9" Click="Export_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,12">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="TOTAL INCOME" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="CalcIncome" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="TOTAL DEDUCTIONS" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="CalcDeductions" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource WarnBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="TAXABLE INCOME / TAX" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="CalcTax" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <ScrollViewer>
            <StackPanel Margin="24,16" MaxWidth="840">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="ORGANIZATION INFORMATION" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Organization Name" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="OrganizationName" Height="30" Text="{Binding OrganizationName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="EIN" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="EIN" Height="30" Text="{Binding EIN, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Address" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="Address" Height="30" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Tax-Exempt Status" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <ComboBox x:Name="TaxExemptStatus" Height="30">
                            <ComboBoxItem Content="501(c)(3) - Charitable"/>
                            <ComboBoxItem Content="501(c)(4) - Social Welfare"/>
                            <ComboBoxItem Content="501(c)(6) - Business League"/>
                        </ComboBox>
                    </StackPanel>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="REVENUE" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="1. Contributions & Grants" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="ContributionsGrants" Height="30" Text="{Binding ContributionsGrants, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="2. Program Service Revenue" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="ProgramServiceRevenue" Height="30" Text="{Binding ProgramServiceRevenue, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="3. Membership Dues" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="MembershipDues" Height="30" Text="{Binding MembershipDues, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="4. Investment Income" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="InvestmentIncome" Height="30" Text="{Binding InvestmentIncome, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="5. Fundraising Events" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="FundraisingEvents" Height="30" Text="{Binding FundraisingEvents, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="8. Other Revenue" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="OtherRevenue" Height="30" Text="{Binding OtherRevenue, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="EXPENSES" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="13. Grants & Similar" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="GrantsSimilar" Height="30" Text="{Binding GrantsSimilar, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="14. Benefits to Members" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="BenefitsToMembers" Height="30" Text="{Binding BenefitsToMembers, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="15. Salaries & Compensation" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="SalariesCompensation" Height="30" Text="{Binding SalariesCompensation, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="16. Professional Fees" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="ProfessionalFees" Height="30" Text="{Binding ProfessionalFees, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="18. Occupancy" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="Occupancy" Height="30" Text="{Binding Occupancy, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="24. Other Expenses" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="OtherExpenses" Height="30" Text="{Binding OtherExpenses, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="NET ASSETS" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Beginning of Year Net Assets" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="BeginNetAssets" Height="30" Text="{Binding BeginNetAssets, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="End of Year Net Assets" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="EndNetAssets" Height="30" Text="{Binding EndNetAssets, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
