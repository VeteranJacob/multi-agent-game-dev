<Page x:Class="HealingTempleLedger.Views.LedgerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="General Ledger">
    <DockPanel Margin="24,20">

        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="📒 General Ledger" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}"/>
                <TextBlock Text="GAAP-compliant double-entry accrual ledger"
                           Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="📥 Import CSV" Margin="0,0,8,0" Click="ImportCsv_Click"/>
                <Button Content="📤 Export CSV" Margin="0,0,8,0" Click="ExportCsv_Click"/>
                <Button Content="📊 Export Excel" Margin="0,0,8,0" Click="ExportExcel_Click"/>
                <Button Content="➕ New Entry" Style="{StaticResource AccentButton}" Click="NewEntry_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Summary Bar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="16,10" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="TOTAL DEBITS" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="TotalDebits" Text="$0.00" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="TOTAL CREDITS" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="TotalCredits" Text="$0.00" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource WarnBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="NET BALANCE" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="NetBalance" Text="$0.00" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="ENTRIES" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="EntryCount" Text="0" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <Separator Style="{StaticResource {x:Type Separator}}" Width="1" Height="40"
                           LayoutTransform="{x:Null}" Margin="0,0,32,0"
                           Background="{StaticResource BorderBrush}"/>
                <!-- Filter -->
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="FILTER CATEGORY" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="{StaticResource MonoFont}"/>
                    <ComboBox x:Name="CategoryFilter" Width="160" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Categories" IsSelected="True"/>
                        <ComboBoxItem Content="Income"/>
                        <ComboBoxItem Content="Business Expense"/>
                        <ComboBoxItem Content="Debt Forgiven"/>
                        <ComboBoxItem Content="Offset"/>
                        <ComboBoxItem Content="Charitable Contribution"/>
                        <ComboBoxItem Content="Trust Distribution"/>
                        <ComboBoxItem Content="Investment Income"/>
                        <ComboBoxItem Content="Capital Gain/Loss"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="SEARCH" FontSize="10" Foreground="{StaticResource TextDimBrush}"
                               FontFamily="{StaticResource MonoFont}"/>
                    <TextBox x:Name="SearchBox" Width="200" TextChanged="Filter_Changed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Add/Edit Row -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Surface2Brush}"
                CornerRadius="8" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                Padding="12,10" Margin="0,0,0,12" x:Name="EditPanel" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Date" Style="{StaticResource {x:Type Label}}" Margin="0,0,0,2"/>
                    <DatePicker x:Name="EntryDate" Background="{StaticResource SurfaceBrush}"
                                Foreground="{StaticResource TextBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Description" Style="{StaticResource {x:Type Label}}" Margin="0,0,0,2"/>
                    <TextBox x:Name="EntryDesc"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Category" Style="{StaticResource {x:Type Label}}" Margin="0,0,0,2"/>
                    <ComboBox x:Name="EntryCategory">
                        <ComboBoxItem Content="Income"/>
                        <ComboBoxItem Content="Business Expense"/>
                        <ComboBoxItem Content="Debt Forgiven (Receivable)"/>
                        <ComboBoxItem Content="Offset (Expense Applied)"/>
                        <ComboBoxItem Content="Charitable Contribution"/>
                        <ComboBoxItem Content="Trust Distribution"/>
                        <ComboBoxItem Content="Investment Income"/>
                        <ComboBoxItem Content="Capital Gain/Loss"/>
                        <ComboBoxItem Content="Other"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <TextBlock Text="Debit (IN)" Style="{StaticResource {x:Type Label}}" Margin="0,0,0,2"/>
                    <TextBox x:Name="EntryDebit" Text="0.00"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="0,0,8,0">
                    <TextBlock Text="Credit (OUT)" Style="{StaticResource {x:Type Label}}" Margin="0,0,0,2"/>
                    <TextBox x:Name="EntryCredit" Text="0.00"/>
                </StackPanel>
                <StackPanel Grid.Column="5" Margin="0,0,8,0">
                    <TextBlock Text="Account Code" Style="{StaticResource {x:Type Label}}" Margin="0,0,0,2"/>
                    <ComboBox x:Name="EntryAccount" DisplayMemberPath="Display" SelectedValuePath="Code"/>
                </StackPanel>
                <StackPanel Grid.Column="6" Margin="0,0,8,0">
                    <TextBlock Text="Reference" Style="{StaticResource {x:Type Label}}" Margin="0,0,0,2"/>
                    <TextBox x:Name="EntryRef"/>
                </StackPanel>
                <StackPanel Grid.Column="7" VerticalAlignment="Bottom">
                    <Button Content="💾 Save" Style="{StaticResource AccentButton}"
                            Margin="0,0,6,0" Click="SaveEntry_Click"/>
                    <Button Content="✕ Cancel" Margin="0,4,0,0" Click="CancelEdit_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Ledger Grid -->
        <DataGrid x:Name="LedgerGrid" IsReadOnly="False"
                  SelectionChanged="LedgerGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=yyyy-MM-dd}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="Account" Binding="{Binding AccountCode}" Width="80" IsReadOnly="True"/>
                <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat=C2}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat=C2}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Net" Binding="{Binding Net, StringFormat=C2}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Ref" Binding="{Binding Reference}" Width="80" IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Actions" Width="100" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="✏" Padding="6,2" Margin="0,0,4,0" Click="EditEntry_Click" Tag="{Binding Id}"/>
                                <Button Content="🗑" Padding="6,2" Style="{StaticResource DangerButton}" Click="DeleteEntry_Click" Tag="{Binding Id}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
