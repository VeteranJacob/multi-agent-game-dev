<Page x:Class="HealingTempleLedger.Views.Form1041Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BgBrush}" Title="🏛 Form 1041">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="28,16">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="🏛 Form 1041" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="U.S. Income Tax Return for Estates and Trusts" Foreground="{StaticResource TextDimBrush}" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="🧮 Calculate" Padding="14,9" Margin="0,0,8,0" Click="Calculate_Click"/>
                    <Button Content="💾 Save" Style="{StaticResource AccentButton}" Padding="14,9" Margin="0,0,8,0" Click="Save_Click"/>
                    <Button Content="📊 Export Excel" Padding="14,9" Click="Export_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="24,12">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="TOTAL INCOME" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="CalcIncome" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="TOTAL DEDUCTIONS" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="CalcDeductions" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource WarnBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="TAXABLE INCOME / TAX" FontSize="10" Foreground="{StaticResource TextDimBrush}" FontFamily="{StaticResource MonoFont}"/>
                    <TextBlock x:Name="CalcTax" Text="—" FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
            </StackPanel>
        </Border>
        <ScrollViewer>
            <StackPanel Margin="24,16" MaxWidth="840">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="TRUST/ESTATE INFORMATION" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Name of Estate or Trust" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="TrustEstateName" Height="30" Text="{Binding TrustEstateName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="EIN" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="EIN" Height="30" Text="{Binding EIN, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Fiduciary Name" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="FiduciaryName" Height="30" Text="{Binding FiduciaryName, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Fiduciary Title" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <ComboBox x:Name="FiduciaryTitle" Height="30">
                            <ComboBoxItem Content="Trustee"/>
                            <ComboBoxItem Content="Executor"/>
                            <ComboBoxItem Content="Administrator"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Type" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <ComboBox x:Name="EntityType" Height="30">
                            <ComboBoxItem Content="Simple Trust"/>
                            <ComboBoxItem Content="Complex Trust"/>
                            <ComboBoxItem Content="Grantor Trust"/>
                            <ComboBoxItem Content="Decedent's Estate"/>
                        </ComboBox>
                    </StackPanel>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="INCOME" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="1. Interest Income" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="InterestIncome" Height="30" Text="{Binding InterestIncome, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="2a. Ordinary Dividends" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="OrdinaryDividends" Height="30" Text="{Binding OrdinaryDividends, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="2b. Qualified Dividends" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="QualifiedDividends" Height="30" Text="{Binding QualifiedDividends, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="4. Capital Gain/Loss" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="CapitalGainLoss" Height="30" Text="{Binding CapitalGainLoss, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="5. Rents, Royalties, etc." Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="RentsRoyalties" Height="30" Text="{Binding RentsRoyalties, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="8. Other Income" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="OtherIncome" Height="30" Text="{Binding OtherIncome, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="DEDUCTIONS" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="10. Interest Expense" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="InterestExpense" Height="30" Text="{Binding InterestExpense, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="11. Taxes" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="Taxes" Height="30" Text="{Binding Taxes, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="12. Fiduciary Fees" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="FiduciaryFees" Height="30" Text="{Binding FiduciaryFees, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="13. Charitable Deduction" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="CharitableDeduction" Height="30" Text="{Binding CharitableDeduction, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="14. Attorney/Accountant Fees" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="AttorneyFees" Height="30" Text="{Binding AttorneyFees, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="15. Other Deductions" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="OtherDeductions" Height="30" Text="{Binding OtherDeductions, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="TAX & PAYMENTS" Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock Text="Estimated Tax Payments" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,3"/>
                        <TextBox x:Name="EstimatedTaxPayments" Height="30" Text="{Binding EstimatedTaxPayments, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
