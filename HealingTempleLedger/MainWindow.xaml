<Window x:Class="HealingTempleLedger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HealingTempleLedger.Views"
        Title="Healing Temple Ledger — Lawful Self-Governance &amp; GAAPCLAW Suite"
        Height="820" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Window.Resources>
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="4,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A3A2A"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavSection" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="Margin" Value="12,10,0,2"/>
            <Setter Property="TextTransform" Value="Uppercase"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── Sidebar ─────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Logo -->
                <Border DockPanel.Dock="Top" Padding="16,18,16,12"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="⚖ Healing Temple Ledger"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Lawful Self-Governance Suite"
                                   Foreground="{StaticResource TextDimBrush}"
                                   FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Version at bottom -->
                <Border DockPanel.Dock="Bottom" Padding="16,10"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                    <TextBlock Text="v1.0.0  ·  redressright.me"
                               Foreground="{StaticResource TextDimBrush}"
                               FontSize="10" FontFamily="{StaticResource MonoFont}"/>
                </Border>

                <!-- Nav -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,6,0,0">

                        <TextBlock Style="{StaticResource NavSection}" Text="Main"/>
                        <RadioButton x:Name="NavDashboard" Style="{StaticResource NavButton}"
                                     GroupName="Nav" IsChecked="True"
                                     Click="Nav_Click" Tag="Dashboard">
                            <TextBlock Text="🏠  Dashboard"/>
                        </RadioButton>

                        <TextBlock Style="{StaticResource NavSection}" Text="Healing Temple Ledger"/>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="HistoricalRecord">
                            <TextBlock Text="📜  Historical Record"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="PetitionRedress">
                            <TextBlock Text="📋  Petition for Redress"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Congressional">
                            <TextBlock Text="🏛  Congressional Petition"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="EmergencyPowers">
                            <TextBlock Text="⚡  Emergency Powers"/>
                        </RadioButton>

                        <TextBlock Style="{StaticResource NavSection}" Text="GAAPCLAW Ledger"/>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Ledger">
                            <TextBlock Text="📒  General Ledger"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Journal">
                            <TextBlock Text="📝  Journal Entries"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="ChartAccounts">
                            <TextBlock Text="📋  Chart of Accounts"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Entities">
                            <TextBlock Text="🏢  Entities"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Statements">
                            <TextBlock Text="📑  Financial Statements"/>
                        </RadioButton>

                        <TextBlock Style="{StaticResource NavSection}" Text="Tax Filings"/>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Form1040">
                            <TextBlock Text="👤  Form 1040"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Form1120">
                            <TextBlock Text="🏢  Form 1120 Corporate"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Form990">
                            <TextBlock Text="🤝  Form 990 Nonprofit"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Form1041">
                            <TextBlock Text="🏛  Form 1041 Trust"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="ScheduleC">
                            <TextBlock Text="💼  Schedule C"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="TaxEstimator">
                            <TextBlock Text="🧮  Tax Estimator"/>
                        </RadioButton>

                        <TextBlock Style="{StaticResource NavSection}" Text="AI Agents"/>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="AIAgent">
                            <TextBlock Text="🤖  AI Agent Chat"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="AIHumanizer">
                            <TextBlock Text="✍  AI Humanizer"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="DocumentCreator">
                            <TextBlock Text="📄  Document Creator"/>
                        </RadioButton>

                        <TextBlock Style="{StaticResource NavSection}" Text="System"/>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Reports">
                            <TextBlock Text="📊  Reports"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavButton}" GroupName="Nav"
                                     Click="Nav_Click" Tag="Settings">
                            <TextBlock Text="⚙  Settings"/>
                        </RadioButton>

                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ── Content Area ────────────────────────────────────────── -->
        <Border Grid.Column="1" x:Name="ContentArea"
                Background="{StaticResource BgBrush}">
            <!-- Views swapped in code-behind -->
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"
                   Background="{StaticResource BgBrush}"/>
        </Border>
    </Grid>
</Window>
